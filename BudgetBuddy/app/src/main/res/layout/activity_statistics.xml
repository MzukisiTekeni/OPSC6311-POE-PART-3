<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/spacing_base">

        <!-- ═══════════════════════════════════════════════════════════════
             SECTION 1 — TIME PERIOD FILTERING
             Navigation and filter chips to switch between day, week, month, etc.
             ═══════════════════════════════════════════════════════════════ -->
        <include layout="@layout/component_simple_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Period chips — Day / Week / Month / 3M / Year -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Day chip -->
                <TextView
                    android:id="@+id/chip_day"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="Day"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingStart="@dimen/spacing_base"
                    android:paddingEnd="@dimen/spacing_base"
                    android:clickable="true" android:focusable="true" />

                <!-- Week chip -->
                <TextView
                    android:id="@+id/chip_week"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_week"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingStart="@dimen/spacing_base"
                    android:paddingEnd="@dimen/spacing_base"
                    android:clickable="true" android:focusable="true" />

                <!-- Month chip — selected by default -->
                <TextView
                    android:id="@+id/chip_month"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/bg_chip_selected"
                    android:text="@string/filter_month"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_on_primary"
                    android:gravity="center"
                    android:paddingStart="@dimen/spacing_base"
                    android:paddingEnd="@dimen/spacing_base"
                    android:clickable="true" android:focusable="true" />

                <!-- 3 Months chip -->
                <TextView
                    android:id="@+id/chip_3months"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_3months"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingStart="@dimen/spacing_base"
                    android:paddingEnd="@dimen/spacing_base"
                    android:clickable="true" android:focusable="true" />

                <!-- Year chip -->
                <TextView
                    android:id="@+id/chip_year"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_year"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingStart="@dimen/spacing_base"
                    android:paddingEnd="@dimen/spacing_base"
                    android:clickable="true" android:focusable="true" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════════════════════════
                 SECTION 2 — SUMMARY METRICS
                 At-a-glance totals and averages for the selected period.
                 ═══════════════════════════════════════════════════════════════ -->
            <!-- Key stats 2×2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="@dimen/spacing_base">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/spacing_base">
                    <TextView
                        android:id="@+id/tv_total_spending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R0"
                        android:textSize="@dimen/text_xxl"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_total_spending"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_daily_average"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R0"
                        android:textSize="@dimen/text_xxl"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_daily_average"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="@dimen/spacing_base">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="@dimen/spacing_base">
                    <TextView
                        android:id="@+id/tv_top_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="–"
                        android:textSize="@dimen/text_xxl"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_top_category"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_vs_last_period"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="–"
                        android:textSize="@dimen/text_xxl"
                        android:textColor="@color/streak_orange"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_vs_last_period"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════════
                 SECTION 3 — VISUAL ANALYSIS
                 Custom bar chart showing spending distribution and goal alignment.
                 ═══════════════════════════════════════════════════════════════ -->
            <!-- Bar chart card — category breakdown for all periods -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_base"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Category Spending vs Budget"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_chart_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Grey = budget · Coloured = spent · Dashed lines = Min/Max goals"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <!--
                        SpendingBarChartView drawn in StatisticsActivity.kt using Canvas.
                        Each period shows category bars (budget vs spent) with min/max goal lines.
                    -->
                    <com.budgetbuddy.app.SpendingBarChartView
                        android:id="@+id/bar_chart"
                        android:layout_width="match_parent"
                        android:layout_height="260dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════════════════════════════
                 SECTION 4 — AI INSIGHTS
                 Personalized spending trends and recommendations.
                 ═══════════════════════════════════════════════════════════════ -->
            <!-- Insights -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/section_insights"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_insights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
