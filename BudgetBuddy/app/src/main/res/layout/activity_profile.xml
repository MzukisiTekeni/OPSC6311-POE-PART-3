<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_profile.xml
    Updated to include working Badges tab panel and Themes tab panel,
    matching the HTML mockup design exactly.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/spacing_base">

        <include layout="@layout/component_simple_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- User info row -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_base">

                <FrameLayout
                    android:id="@+id/fl_avatar"
                    android:layout_width="@dimen/avatar_size_lg"
                    android:layout_height="@dimen/avatar_size_lg"
                    android:background="@drawable/bg_avatar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView
                        android:id="@+id/tv_avatar_initials"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="MT"
                        android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_xl"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/ll_user_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_base"
                    app:layout_constraintStart_toEndOf="@id/fl_avatar"
                    app:layout_constraintEnd_toStartOf="@id/tv_level_badge"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textSize="@dimen/text_lg"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/member_since"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_hint" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_level_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_level_badge"
                    android:text="★ Lv 1"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/xp_yellow"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_xs"
                    android:paddingBottom="@dimen/spacing_xs"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Stats row -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_base"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_base"
                    android:weightSum="3">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_day_streak"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="@dimen/text_xxl"
                            android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_day_streak" android:textSize="@dimen/text_xs" android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/divider_line" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_total_xp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="@dimen/text_xxl"
                            android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_total_xp" android:textSize="@dimen/text_xs" android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/divider_line" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_total_saved"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="R0" android:textSize="@dimen/text_xxl"
                            android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_saved" android:textSize="@dimen/text_xs" android:textColor="@color/text_hint" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- XP / Badges / Themes tabs card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_base"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <!-- Tab row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <TextView android:id="@+id/tab_xp"
                            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                            android:background="@drawable/bg_chip_selected"
                            android:text="@string/tab_xp" android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_on_primary" android:gravity="center"
                            android:clickable="true" android:focusable="true" />

                        <TextView android:id="@+id/tab_badges"
                            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                            android:background="@drawable/bg_chip_unselected"
                            android:text="@string/tab_badges" android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_secondary" android:gravity="center"
                            android:clickable="true" android:focusable="true" />

                        <TextView android:id="@+id/tab_themes"
                            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                            android:background="@drawable/bg_chip_unselected"
                            android:text="@string/tab_themes" android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_secondary" android:gravity="center"
                            android:clickable="true" android:focusable="true" />
                    </LinearLayout>

                    <!-- ══════════════════════════ XP PANEL ══════════════════════════ -->
                    <LinearLayout
                        android:id="@+id/panel_xp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_base">

                        <!-- XP level title row -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:id="@+id/tv_xp_level_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_level"
                                android:textSize="@dimen/text_sm"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent" />
                            <TextView
                                android:id="@+id/tv_xp_fraction"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 / 2000 XP"
                                android:textSize="@dimen/text_xs"
                                android:textColor="@color/text_hint"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <ProgressBar
                            android:id="@+id/progress_xp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/progress_height_sm"
                            android:max="100" android:progress="0"
                            android:progressDrawable="@drawable/progress_bar_green" />

                        <TextView
                            android:id="@+id/tv_xp_hint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/xp_next_level"
                            android:textSize="@dimen/text_xs"
                            android:textColor="@color/text_hint" />

                        <!-- Divider -->
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/divider_line"
                            android:layout_marginTop="@dimen/spacing_base"
                            android:layout_marginBottom="@dimen/spacing_sm" />

                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:text="@string/section_how_to_earn"
                            android:textSize="@dimen/text_sm" android:textColor="@color/text_hint" />

                        <include layout="@layout/item_xp_earn_row" android:id="@+id/row_log_expense"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm" />

                        <include layout="@layout/item_xp_earn_row" android:id="@+id/row_stay_budget"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <include layout="@layout/item_xp_earn_row" android:id="@+id/row_complete_goal"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs" />
                    </LinearLayout>

                    <!-- ═══════════════════════ BADGES PANEL ═══════════════════════ -->
                    <LinearLayout
                        android:id="@+id/panel_badges"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_base"
                        android:visibility="gone">

                        <!-- Badge grid — 3 columns × 3 rows = 9 badges -->
                        <GridLayout
                            android:id="@+id/grid_badges"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="3"
                            android:rowCount="3"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <!-- Badge 1: First budget -->
                            <LinearLayout
                                android:id="@+id/badge_first_budget"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_first_budget"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_badge_circle">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="🏆" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_first_budget"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="First budget"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 2: 7-day streak -->
                            <LinearLayout
                                android:id="@+id/badge_streak_7"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_streak_7"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_streak_badge">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="🔥" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_streak_7"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="7-day streak"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 3: First saver -->
                            <LinearLayout
                                android:id="@+id/badge_first_saver"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_first_saver"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_xp_badge">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="💰" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_first_saver"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="First saver"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 4: 30-day streak -->
                            <LinearLayout
                                android:id="@+id/badge_streak_30"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_streak_30"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_badge_circle">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="🎯" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_streak_30"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="30-day streak"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 5: All goals -->
                            <LinearLayout
                                android:id="@+id/badge_all_goals"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_all_goals"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_goal_circle">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="⭐" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_all_goals"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="All goals"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 6: Budget master -->
                            <LinearLayout
                                android:id="@+id/badge_budget_master"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_budget_master"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_badge_circle">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="📊" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_budget_master"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="Budget master"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 7: No-spend day -->
                            <LinearLayout
                                android:id="@+id/badge_no_spend_day"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_no_spend_day"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_badge_circle">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="🏅" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_no_spend_day"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="No-spend day"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 8: Goal crusher -->
                            <LinearLayout
                                android:id="@+id/badge_goal_crusher"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_goal_crusher"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_badge_circle">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="🚀" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_goal_crusher"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="Goal crusher"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                            <!-- Badge 9: Consistent saver -->
                            <LinearLayout
                                android:id="@+id/badge_consistent_saver"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="6dp">
                                <FrameLayout
                                    android:id="@+id/badge_circle_consistent_saver"
                                    android:layout_width="44dp" android:layout_height="44dp"
                                    android:background="@drawable/bg_badge_circle">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:layout_gravity="center" android:text="💎" android:textSize="20sp"/>
                                </FrameLayout>
                                <TextView android:id="@+id/badge_lbl_consistent_saver"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="Consistent saver"
                                    android:textSize="9sp" android:textColor="@color/text_hint"
                                    android:gravity="center" android:maxLines="2" />
                            </LinearLayout>

                        </GridLayout>

                        <!-- Badge count hint row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/surface_secondary"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="8dp" android:paddingBottom="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:id="@+id/tv_badge_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 of 9 badges earned"
                                android:textSize="10sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ═══════════════════════ THEMES PANEL ══════════════════════ -->
                    <LinearLayout
                        android:id="@+id/panel_themes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_base"
                        android:visibility="gone">

                        <!-- Theme swatches row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="5"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <!-- Forest (always active/unlocked) -->
                            <LinearLayout
                                android:id="@+id/theme_forest"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="3dp"
                                android:background="@drawable/bg_card"
                                android:paddingBottom="4dp">
                                <View android:id="@+id/theme_bar_forest"
                                    android:layout_width="match_parent" android:layout_height="28dp"
                                    android:background="#2D6A4F"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_marginTop="3dp"
                                    android:text="Forest" android:textSize="9sp" android:textColor="@color/primary"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView android:id="@+id/theme_sub_forest"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:text="Active" android:textSize="8sp" android:textColor="@color/primary" />
                            </LinearLayout>

                            <!-- Ocean (unlocked at 500 XP) -->
                            <LinearLayout
                                android:id="@+id/theme_ocean"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
                                android:background="@drawable/bg_card"
                                android:paddingBottom="4dp">
                                <View android:id="@+id/theme_bar_ocean"
                                    android:layout_width="match_parent" android:layout_height="28dp"
                                    android:background="#185FA5"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_marginTop="3dp"
                                    android:text="Ocean" android:textSize="9sp" android:textColor="@color/text_secondary" />
                                <TextView android:id="@+id/theme_sub_ocean"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:text="500 XP" android:textSize="8sp" android:textColor="@color/text_hint" />
                            </LinearLayout>

                            <!-- Midnight (unlocked at 2000 XP) -->
                            <LinearLayout
                                android:id="@+id/theme_midnight"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
                                android:background="@drawable/bg_card"
                                android:paddingBottom="4dp">
                                <View android:id="@+id/theme_bar_midnight"
                                    android:layout_width="match_parent" android:layout_height="28dp"
                                    android:background="#1A1A2E"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_marginTop="3dp"
                                    android:text="Midnight" android:textSize="9sp" android:textColor="@color/text_secondary" />
                                <TextView android:id="@+id/theme_sub_midnight"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:text="2k XP" android:textSize="8sp" android:textColor="@color/text_hint" />
                            </LinearLayout>

                            <!-- Violet (unlocked at 5000 XP) -->
                            <LinearLayout
                                android:id="@+id/theme_violet"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
                                android:background="@drawable/bg_card"
                                android:paddingBottom="4dp">
                                <View android:id="@+id/theme_bar_violet"
                                    android:layout_width="match_parent" android:layout_height="28dp"
                                    android:background="#534AB7"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_marginTop="3dp"
                                    android:text="Violet" android:textSize="9sp" android:textColor="@color/text_secondary" />
                                <TextView android:id="@+id/theme_sub_violet"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:text="5k XP" android:textSize="8sp" android:textColor="@color/text_hint" />
                            </LinearLayout>

                            <!-- Amber (unlocked at 3500 XP) -->
                            <LinearLayout
                                android:id="@+id/theme_amber"
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="3dp"
                                android:background="@drawable/bg_card"
                                android:paddingBottom="4dp">
                                <View android:id="@+id/theme_bar_amber"
                                    android:layout_width="match_parent" android:layout_height="28dp"
                                    android:background="#854F0B"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_marginTop="3dp"
                                    android:text="Amber" android:textSize="9sp" android:textColor="@color/text_secondary" />
                                <TextView android:id="@+id/theme_sub_amber"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_gravity="center_horizontal"
                                    android:text="3.5k XP" android:textSize="8sp" android:textColor="@color/text_hint" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- XP nudge hint row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/accent_green_light"
                            android:paddingStart="11dp" android:paddingEnd="11dp"
                            android:paddingTop="9dp" android:paddingBottom="9dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:id="@+id/tv_theme_xp_hint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Earn XP to unlock more themes!"
                                android:textSize="10sp"
                                android:textColor="@color/primary_dark"
                                android:lineSpacingMultiplier="1.3" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Settings card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:text="@string/section_settings"
                        android:textSize="@dimen/text_body" android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" android:textStyle="bold" />

                    <include layout="@layout/item_settings_row" android:id="@+id/row_notifications"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginVertical="@dimen/spacing_xs" />

                    <include layout="@layout/item_settings_row" android:id="@+id/row_currency"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginVertical="@dimen/spacing_xs" />

                    <include layout="@layout/item_settings_row" android:id="@+id/row_privacy"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginVertical="@dimen/spacing_xs" />

                    <include layout="@layout/item_settings_row" android:id="@+id/row_clear_data"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_line" android:layout_marginVertical="@dimen/spacing_xs" />

                    <include layout="@layout/item_settings_row" android:id="@+id/row_signout"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
