<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    android:padding="@dimen/screen_padding">

    <include layout="@layout/component_simple_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- App logo -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="@dimen/spacing_xl"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_quick_action">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/bb_logo_1_1"
            android:contentDescription="BudgetBuddy logo" />
    </FrameLayout>

    <!-- Heading -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:text="@string/reset_password_heading"
        android:textSize="28sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <!-- Email label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:text="@string/label_email"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium" />

    <EditText
        android:id="@+id/et_reset_email"
        style="@style/Style.InputField"
        android:layout_marginTop="@dimen/spacing_xs"
        android:hint="@string/hint_reset_email"
        android:inputType="textEmailAddress"
        android:imeOptions="actionDone" />

    <!-- Send button -->
    <Button
        android:id="@+id/btn_send_password"
        style="@style/Style.PrimaryButton"
        android:layout_marginTop="@dimen/spacing_xl"
        android:text="@string/btn_send_password" />

</LinearLayout>
