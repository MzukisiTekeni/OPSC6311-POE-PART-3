<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_expense_categories.xml
    Shows a scrollable checklist of preset expense categories + a custom "Other" add row.
    RecyclerView is populated in ExpenseCategoriesActivity with CategoryItem data class.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm">

        <!-- ═══════════════════════════════════════════════════════════════
             SECTION 1 — HEADER & GUIDANCE
             Screen title and instructions for selecting categories.
             ═══════════════════════════════════════════════════════════════ -->
        <include layout="@layout/component_simple_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/subtitle_expense_categories"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 2 — CATEGORY LIST
         Checklist of available spending categories.
         ═══════════════════════════════════════════════════════════════ -->
    <!-- Category list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_categories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:clipToPadding="false" />

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 3 — CUSTOM ADDITION
         Input field for adding personalized categories.
         ═══════════════════════════════════════════════════════════════ -->
    <!-- "Other" custom category row -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/spacing_base"
        app:cardCornerRadius="@dimen/card_radius_sm"
        app:cardElevation="@dimen/card_elevation"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/spacing_base"
            android:paddingEnd="@dimen/spacing_sm">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/category_other"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/et_custom_category"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@android:color/transparent"
                android:hint="@string/hint_category_name"
                android:textSize="@dimen/text_body"
                android:textColorHint="@color/text_hint"
                android:imeOptions="actionDone"
                android:inputType="text" />

            <Button
                android:id="@+id/btn_add_custom"
                android:layout_width="56dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_btn_primary"
                android:text="@string/btn_add"
                android:textColor="@color/text_on_primary"
                android:textSize="@dimen/text_xs"
                android:layout_marginStart="@dimen/spacing_xs" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════════════════════════════
         SECTION 4 — FINALISATION
         Confirms selection and proceeds to the dashboard.
         ═══════════════════════════════════════════════════════════════ -->
    <!-- Continue button -->
    <Button
        android:id="@+id/btn_continue"
        style="@style/Style.PrimaryButton"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:layout_width="match_parent"
        android:text="@string/btn_continue" />

</LinearLayout>
